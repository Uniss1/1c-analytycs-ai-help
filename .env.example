# LLM (Ollama) — base URL, GPU ports derived as base+0, base+1, base+2
OLLAMA_BASE_URL=http://localhost:11434
# Override per-GPU URLs if ports differ from base+offset:
# OLLAMA_ROUTER_URL=http://localhost:11434
# OLLAMA_QUERY_URL=http://localhost:11435
# OLLAMA_FORMATTER_URL=http://localhost:11436
MODEL_NAME=qwen3.5:4b

# 1C HTTP service
ONEC_BASE_URL=http://1c-server/base/hs/ai
ONEC_USER=ai_assistant
ONEC_PASSWORD=

# ai-chat (knowledge base service, Uniss1/ai-chat)
WIKI_BASE_URL=http://wiki-server:3001
WIKI_TIMEOUT=30

# Limits
QUERY_TIMEOUT=30
QUERY_ROW_LIMIT=1000
RATE_LIMIT_PER_MINUTE=30
